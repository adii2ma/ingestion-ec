# On EC2, AWS credentials should come from the instance IAM role.
# Do not put AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here for that setup.
AWS_REGION=us-east-1

# Optional manual-ingestion defaults. SQS messages provide bucket/key automatically.
S3_BUCKET=your-bucket-name
# S3_KEY=semester-5/Operating Systems/processes.pdf

# SQS queue receiving S3 ObjectCreated notifications.
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue
SQS_WAIT_SECONDS=20
SQS_MAX_MESSAGES=5

# Option A: one complete PostgreSQL connection string.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ingest

# Option B: Aurora PostgreSQL fields. Used when DATABASE_URL is not set.
DB_HOST=your-aurora-cluster.cluster-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ingest
DB_USER=postgres
DB_PASSWORD=your-password
DB_SSLMODE=require

# OpenAI embedding settings.
OPENAI_API_KEY=sk-your-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=128

# Chunking controls. Start here, then tune by retrieval quality.
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
