# AWS credentials can also come from your normal AWS profile, IAM role, or ECS/EKS task role.
AWS_REGION=us-east-1

# S3 object to ingest when CLI flags are not provided.
S3_BUCKET=your-bucket-name
S3_KEY=documents/example.pdf

# Aurora PostgreSQL connection string. Use the psycopg driver name.
# Format: postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ingest

# OpenAI embedding settings.
OPENAI_API_KEY=sk-your-key
EMBEDDING_MODEL=text-embedding-3-small

# LangChain PGVector collection name.
PGVECTOR_COLLECTION=documents

# Chunking controls. Start here, then tune by retrieval quality.
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

